{
  "name": "Linktree",
  "framework": "vanilla",
  "port": 8001,
  "src": "src",
  "dist": "dist",
  "build": [
    {
      "_doc": "Wrap every *.json in src/data/ as a globalThis.PORTAL_DATA[<key>] companion (data-*.json.js). Engine: front-data-json-js-wrapper.sh.",
      "mod": "data_wrap",
      "dir": "src/data"
    },
    {
      "_doc": "Generate the full PWA app-icon set from one source image. Idempotent — skips when outputs are newer than source. Re-runs only when public/favicon.jpg changes.",
      "mod": "pwa_icons",
      "source": "src/public/favicon.jpg",
      "out": "src/public/pwa",
      "bg": "#000000"
    },
    {
      "mod": "esbuild",
      "input": "src/typescript/main.ts",
      "output": "script.js",
      "format": "iife",
      "target": "es2020"
    },
    {
      "mod": "sass",
      "input": "src/scss/main.scss",
      "output": "style.css"
    },
    {
      "mod": "copy",
      "files": "index.html",
      "from": "src"
    },
    {
      "mod": "copy",
      "files": "manifest.webmanifest",
      "from": "src"
    },
    {
      "_doc": "Deploy the data-*.json.js wrappers from the linktree-owned data hub to dist root, so any consumer can <script src=\"data-NAME.json.js\"> with no fetch / no CORS. Source-of-truth lives in linktree/src/data/ (linktree owns the link data; sibling projects symlink in).",
      "mod": "copy",
      "files": "data-*.json.js",
      "from": "src/data"
    },
    {
      "mod": "symlink",
      "files": "src/public"
    },
    {
      "_doc": "MUST run last — hashes the dist artifacts above to derive BUILD_HASH and inject it into the SW bundle.",
      "mod": "esbuild_sw",
      "input": "src/typescript/script-service-worker.ts",
      "output": "script-service-worker.js",
      "format": "iife",
      "target": "es2020",
      "hash_of": [
        "index.html",
        "script.js",
        "style.css"
      ],
      "precache": [
        "./",
        "./index.html",
        "./style.css",
        "./script.js",
        "./public/swiper.min.css",
        "./public/swiper.min.js"
      ]
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "src",
    "watch": [
      {
        "mod": "sass",
        "input": "scss/main.scss",
        "output": "style.css"
      },
      {
        "mod": "esbuild",
        "input": "typescript/main.ts",
        "output": "script.js",
        "format": "iife",
        "target": "es2020"
      }
    ]
  },
  "deploy": {}
}
