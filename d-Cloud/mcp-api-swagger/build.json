{
  "name": "mcp-api-swagger",
  "framework": "vanilla",
  "port": 8024,
  "src": "src",
  "dist": "dist",
  "build": [
    {
      "_doc": "Wrap every *.json in src/data/ as a globalThis.PORTAL_DATA[<key>] companion (data-*.json.js). Engine: front-data-json-js-wrapper.sh.",
      "mod": "data_wrap",
      "dir": "src/data"
    },
    {
      "_doc": "Ship the wrapped data-*.json.js companions to dist/ root, so HTML can load them with <script src=\"data-<KEY>.json.js\"></script> — no fetch, no CORS.",
      "mod": "copy",
      "files": "data-*.json.js",
      "from": "src/data"
    },
    {
      "mod": "sass",
      "input": "src/scss/main.scss",
      "output": "style.css"
    },
    {
      "mod": "esbuild",
      "input": "src/typescript/main.ts",
      "output": "script.js",
      "format": "iife",
      "target": "es2020"
    },
    {
      "mod": "copy",
      "files": "*.html,c3-dash.js,api-page.js",
      "from": "src"
    },
    {
      "_doc": "MUST run last — hashes the dist artifacts above to derive BUILD_HASH and inject it into the SW bundle.",
      "mod": "esbuild_sw",
      "input": "src/typescript/script-service-worker.ts",
      "output": "script-service-worker.js",
      "format": "iife",
      "target": "es2020",
      "hash_of": [
        "affine-api.html",
        "api-page.js",
        "authelia-api.html",
        "c3-api.html",
        "c3-dash.js",
        "c3-infra-mcp-api.html",
        "c3-services-mcp-api.html",
        "crawlee-api.html",
        "index.html",
        "mailu-api.html",
        "matomo-api.html",
        "mattermost-api.html",
        "nocodb-api.html",
        "ntfy-api.html",
        "photoprism-api.html",
        "radicale-api.html",
        "script.js",
        "style.css",
        "syncthing-api.html",
        "unix-mcp.html",
        "vaultwarden-api.html",
        "windmill-api.html"
      ],
      "precache": [
        "./",
        "./affine-api.html",
        "./api-page.js",
        "./authelia-api.html",
        "./c3-api.html",
        "./c3-dash.js",
        "./c3-infra-mcp-api.html",
        "./c3-services-mcp-api.html",
        "./crawlee-api.html",
        "./index.html",
        "./mailu-api.html",
        "./matomo-api.html",
        "./mattermost-api.html",
        "./nocodb-api.html",
        "./ntfy-api.html",
        "./photoprism-api.html",
        "./radicale-api.html",
        "./script.js",
        "./style.css",
        "./syncthing-api.html",
        "./unix-mcp.html",
        "./vaultwarden-api.html",
        "./windmill-api.html"
      ]
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "src",
    "watch": [
      {
        "mod": "sass",
        "input": "scss/main.scss",
        "output": "style.css"
      },
      {
        "mod": "esbuild",
        "input": "typescript/main.ts",
        "output": "script.js",
        "format": "iife",
        "target": "es2020"
      }
    ]
  },
  "deploy": {}
}
