{
  "name": "SlabTwin 3D Warehouse",
  "framework": "vanilla",
  "port": 8020,
  "src": "src",
  "dist": "dist",
  "build": [
    {
      "_doc": "Copy index.html to dist root",
      "mod": "copy",
      "files": "*.html",
      "from": "src"
    },
    {
      "_doc": "Ship css/ module folder as-is (symlinked in dev, resolved to real files on deploy)",
      "mod": "symlink",
      "files": "src/css"
    },
    {
      "_doc": "Ship js/ ES module folder as-is (native <script type=module>, no bundler needed)",
      "mod": "symlink",
      "files": "src/js"
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "src"
  },
  "deploy": {}
}
