{
  "name": "SlabTwin 3D Warehouse",
  "framework": "vanilla",
  "port": 8020,
  "src": "src",
  "dist": "dist",
  "build": [
    {
      "_doc": "Copy index.html to dist root",
      "mod": "copy",
      "files": "*.html",
      "from": "src"
    },
    {
      "_doc": "Ship css/ module folder as-is (symlinked in dev, resolved to real files on deploy)",
      "mod": "symlink",
      "files": "src/css"
    },
    {
      "_doc": "Ship js/ ES module folder as-is (native <script type=module>, no bundler needed)",
      "mod": "symlink",
      "files": "src/js"
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "src"
  },
  "deploy": {},
  "_resolved": {
    "path": "a-Projects/Warehouse",
    "category": "a-Projects",
    "project": "Warehouse",
    "key": "a-Projects__Warehouse",
    "port": 8020,
    "framework": "vanilla",
    "src": "src",
    "dist": "dist",
    "analytics": {
      "matomo": {
        "container_id": "container_odwLIyPV",
        "url": "https://analytics.diegonmarcos.com/js/container_odwLIyPV.js"
      },
      "umami": {
        "site_id": "937cbde7-5ec2-450c-9d6a-8117423ac12f",
        "url": "https://analytics.diegonmarcos.com/umami/script.js"
      }
    },
    "deploy": {
      "deployed": true,
      "deploy_name": "Warehouse",
      "url": "https://diegonmarcos.github.io/Warehouse"
    },
    "consumers": [],
    "has_package_json": true,
    "has_manifest": false
  }
}
