{
  "name": "FinTerminal",
  "framework": "vanilla",
  "port": 8024,
  "src": "src",
  "dist": "dist",

  "api": {
    "base": "https://api.diegonmarcos.com/fin-api",
    "ws": "wss://api.diegonmarcos.com/fin-api/api/v1/ws"
  },

  "apps": {
    "valuation": {
      "url": "/valuation/",
      "_note": "Valuation Modelling section. Set to empty string to show placeholder until the valuation app is wired."
    },
    "fx_hedge": {
      "url": "public/fx-hedge.html",
      "_note": "FX Hedge Cost screen — standalone Tailwind+Chart.js HTML page bundled in src/public/."
    }
  },

  "build": [
    { "mod": "sass", "input": "src/scss/main.scss", "output": "style.css" },
    { "mod": "esbuild", "input": "src/typescript/main.ts", "output": "script.js", "format": "iife", "target": "es2020" },
    { "mod": "copy", "files": "index.html", "from": "src" },
    { "mod": "symlink", "files": "public" }
  ],

  "serve": {
    "mode": "auto",
    "dir": "src",
    "watch": [
      { "mod": "sass", "input": "scss/main.scss", "output": "style.css" },
      { "mod": "esbuild", "input": "typescript/main.ts", "output": "script.js", "format": "iife", "target": "es2020" }
    ]
  },

  "deploy": {}
}
