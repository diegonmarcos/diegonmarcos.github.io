#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║ pre-commit — block secrets from ever reaching a commit           ║
# ║                                                                  ║
# ║ Source: cloud/1_workflows/src/hooks/pre-commit                     ║
# ║ Deploy: build.sh workflow → 1_workflows/dist/hooks/                ║
# ║ Active: via .gitconfig [core] hooksPath = 1_workflows/dist/hooks   ║
# ║                                                                  ║
# ║ KEEP IN SYNC with .gitignore patterns.                           ║
# ║ Catches secrets even after git add -f (gitignore bypass).        ║
# ╚══════════════════════════════════════════════════════════════════╝
set -uo pipefail  # no -e: grep exit codes are handled by || true

STAGED=$(git diff --cached --name-only)
[ -z "$STAGED" ] && exit 0

BLOCKED=""

# ── UNIVERSAL GITIGNORE-BYPASS DETECTOR ──────────────────
# Catches ANY file staged despite a matching .gitignore rule (i.e.
# force-staged via `git add -f`). Highest-value defence — gitignore
# exists precisely to keep secrets out; `-f` is the common leak vector.
# --no-index forces evaluation of gitignore rules as if unindexed
# (git check-ignore otherwise silently skips files in the index).
# Only fire for files NOT in HEAD (tracked-path edits are fine).
FORCED=""
while IFS= read -r f; do
  [ -n "$f" ] || continue
  [ -e "$f" ] || continue
  if git check-ignore --no-index -q -- "$f" 2>/dev/null \
     && ! git cat-file -e "HEAD:$f" 2>/dev/null; then
    FORCED="${FORCED}${f}"$'\n'
  fi
done <<< "$STAGED"

if [ -n "$FORCED" ]; then
  echo "══════════════════════════════════════════════════" >&2
  echo "BLOCKED: gitignored files force-staged (git add -f)" >&2
  echo "══════════════════════════════════════════════════" >&2
  echo "$FORCED" | sort -u | sed '/^$/d' | while IFS= read -r f; do
    rule=$(git check-ignore --no-index -v -- "$f" 2>/dev/null | head -1)
    echo "  - $f" >&2
    [ -n "$rule" ] && echo "      matches: $rule" >&2
  done
  echo "NEVER use 'git add -f' / '--force' to override gitignore." >&2
  exit 1
fi

# ── SUBMODULE GITLINK AUTO-UNSTAGE ───────────────────────
# Submodule pointer changes (mode 160000) belong in the submodule's
# own repo; the parent repo gets bumped via auto-sync GHA, not by
# manual commits. Auto-unstage rather than block so the rest of the
# commit can proceed. Data-driven from .gitmodules — no hardcoded
# names, portable across any repo.
if [ -f .gitmodules ]; then
  SUBMODULE_PATHS=$(git config --file .gitmodules --get-regexp 'submodule\..*\.path' 2>/dev/null | awk '{print $2}')
  if [ -n "$SUBMODULE_PATHS" ]; then
    UNSTAGED_SUBS=""
    while IFS= read -r _sm_path; do
      [ -n "$_sm_path" ] || continue
      while IFS= read -r f; do
        [ -n "$f" ] || continue
        case "$f" in
          "$_sm_path"|"$_sm_path"/*)
            UNSTAGED_SUBS="${UNSTAGED_SUBS}${f}"$'\n'
            git reset -q HEAD -- "$f"
            ;;
        esac
      done <<< "$STAGED"
    done <<< "$SUBMODULE_PATHS"
    unset _sm_path

    if [ -n "$UNSTAGED_SUBS" ]; then
      echo "──────────────────────────────────────────────────" >&2
      echo "INFO: auto-unstaged submodule pointers (sync via GHA)" >&2
      echo "──────────────────────────────────────────────────" >&2
      echo "$UNSTAGED_SUBS" | sort -u | sed '/^$/d' | while IFS= read -r f; do
        echo "  - $f" >&2
      done
      echo "Continuing with remaining staged changes." >&2
      echo "──────────────────────────────────────────────────" >&2
      STAGED=$(git diff --cached --name-only)
      [ -z "$STAGED" ] && exit 0
    fi
  fi
fi

add_blocked() {
  local matches
  matches=$(echo "$STAGED" | eval "$1" || true)
  [ -n "$matches" ] && BLOCKED="${BLOCKED}${matches}"$'\n'
}

# ── Secrets & Credentials ────────────────────────────────

# P1: .secrets and .secrets.d/ (dot-prefixed)
add_blocked "grep -E '(^|/)\.secrets(/|$)'"

# P2: *.secrets (any file ending in .secrets)
add_blocked "grep -E '\.secrets$'"

# P3: decrypted sops output in dist/
add_blocked "grep -E 'dist/\.secrets'"

# ── Environment files ────────────────────────────────────

# P4: .env files (not .example or .template)
add_blocked "grep -E '(^|/)\.env(\.|$)' | grep -v '\.example' | grep -v '\.template'"

# ── Private keys & certificates ──────────────────────────

# P5: private keys (id_rsa, id_ed25519, id_ecdsa) — exclude _PUB
add_blocked "grep -iE '(id_rsa|id_ed25519|id_ecdsa)$' | grep -iv '_PUB$'"

# P6: key/cert files (.pem, .key, .p12, .pfx, .jks, .keystore)
add_blocked "grep -iE '\.(pem|key|p12|pfx|jks|keystore)$'"

# ── Auth tokens & credentials ────────────────────────────

# P7: token files
add_blocked "grep -iE '\.token$'"

# P8: credentials JSON files
add_blocked "grep -iE 'credentials.*\.json$'"

# P9: *_token.json / *_tokens.json
add_blocked "grep -iE '_tokens?\.json$'"

# ── Cloud provider configs ───────────────────────────────

# P10: .oci/ and .gcloud/ directories
add_blocked "grep -E '(^|/)\.(oci|gcloud)/'"

# ── GPG & age ────────────────────────────────────────────

# P11: GPG armored files
add_blocked "grep -iE '\.asc$'"

# P12: age key files (not .age.pub)
add_blocked "grep -iE '\.age$' | grep -v '\.age\.pub$'"

# P13: age.key and keys.txt
add_blocked "grep -iE '(age\.key|keys\.txt)$'"

# ── Terraform secrets ────────────────────────────────────

# P14: .tfvars files (not .tfvars.example)
add_blocked "grep -iE '\.tfvars$' | grep -v '\.example$'"

# P15: terraform.tfvars specifically
add_blocked "grep -E '(^|/)terraform\.tfvars$'"

# P17: dist layout v2 gitignored sub-dirs
add_blocked "grep -E 'dist/(secrets|sensitive|\.build)/'"

# ── CONTENT-SCAN: secret-named file MUST be sops-encrypted ─────────
# Filename alone is insufficient — the 2026-04-17 stalwart leak was a
# `secrets.yaml.new` with plaintext content committed to a public repo.
# Right defense: if filename contains secret-like tokens, the content
# MUST contain `ENC[AES` or `sops:` markers. Otherwise → BLOCK.
# This ALLOWS secrets.yaml/.new/.draft/etc. — as long as sops-encrypted.
LEAKY=""
while IFS= read -r f; do
    [ -n "$f" ] || continue
    [ -f "$f" ] || continue
    echo "$f" | grep -iqE '(secret|credential|password|token|jwks|dkim|\.pem$|\.key$)' || continue
    # sops-encrypted? (ENC[AES...] somewhere OR a sops footer with ENC[)
    grep -q 'ENC\[AES' "$f" 2>/dev/null && continue
    grep -q '^sops:' "$f" 2>/dev/null && grep -q 'ENC\[' "$f" 2>/dev/null && continue
    # Allow-listed filename patterns (references/templates, not values)
    case "$f" in
        *.example|*.template|*.tpl|*.pub|*_PUB) continue ;;
        */.secrets-hash*|*/.secrets-env-var-names*) continue ;;
        *secrets-env-var-names*.json|*cloud-data-secrets-env-var-names.json) continue ;;
        *secrets-subst.nix) continue ;;
        # GitHub Actions workflow YAMLs (engine paths): named-about-secrets
        # files here (e.g. lint-secrets-coverage.yml) define CI lint/audit
        # jobs — never secret containers. Required GHA shape: on: + jobs:.
        .github/workflows/*.yml|1_workflows/src/cicd/*.yml|1_workflows/dist/*.yml)
            if grep -qE '^on:' "$f" 2>/dev/null && grep -qE '^jobs:' "$f" 2>/dev/null; then
                continue
            fi
            ;;
    esac
    # Code files: only flag if contain obvious inline values
    case "$f" in
        *.sh|*.py|*.nix|*.ts|*.js|*.go|*.rs|*.md|*.json)
            if grep -qiE '^[[:space:]]*(password|admin_password|private_key|api_key|secret)[[:space:]]*[:=][[:space:]]*[^{$_-]' "$f" 2>/dev/null; then
                LEAKY="${LEAKY}${f} (code file with inline secret pattern)"$'\n'
            fi
            continue
        ;;
    esac
    # YAML/TOML/etc. with secret-ish name and no sops markers → LEAK
    LEAKY="${LEAKY}${f}"$'\n'
done <<< "$STAGED"

if [ -n "$LEAKY" ]; then
  echo "══════════════════════════════════════════════════" >&2
  echo "BLOCKED: secret-named file staged WITHOUT sops encryption" >&2
  echo "══════════════════════════════════════════════════" >&2
  echo "$LEAKY" | sort -u | sed '/^$/d' | while IFS= read -r f; do
    echo "  - $f" >&2
  done
  echo "" >&2
  echo "The file matches (secret|credential|password|token|jwks|dkim|*.pem|*.key)." >&2
  echo "It MUST be sops-encrypted (ENC[AES...]) before commit." >&2
  echo "Fix: sops -e -i <file>   OR   git reset HEAD <file>" >&2
  echo "══════════════════════════════════════════════════" >&2
  exit 1
fi

# ── Deduplicate and check ────────────────────────────────
BLOCKED=$(echo "$BLOCKED" | sort -u | sed '/^$/d')

if [ -n "$BLOCKED" ]; then
  echo "══════════════════════════════════════════════════" >&2
  echo "BLOCKED: secrets or private keys staged for commit" >&2
  echo "══════════════════════════════════════════════════" >&2
  echo "$BLOCKED" | while IFS= read -r f; do
    echo "  - $f" >&2
  done
  echo "" >&2
  echo "To unstage: git reset HEAD <file>" >&2
  echo "NO BYPASS EXISTS. Remove the secret files first." >&2
  echo "══════════════════════════════════════════════════" >&2
  exit 1
fi

# ══════════════════════════════════════════════════════════
# Regenerate 2_configs/dist/ if any engine input changed
# Triggers on staged changes to: engine code, per-service build.json,
# per-VM home-manager build.json, or root config.json.
# Auto-stages any resulting diffs so dist/ stays in sync with src/.
# Skip when already inside a regen commit (guard against hook re-entry).
# ══════════════════════════════════════════════════════════
if [ -z "${SKIP_CONFIGS_REGEN:-}" ] \
   && echo "$STAGED" | grep -qE '^(2_configs/src/engines/|a_solutions/[^/]+/build\.json$|b_infra/nixhm-sudo-[^/]+/build\.json$|config\.json$)'; then
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  BUILD_SH="$REPO_ROOT/2_configs/build.sh"
  if [ -x "$BUILD_SH" ]; then
    echo "[pre-commit] engine input staged — regenerating 2_configs/dist/"
    if ! SKIP_CONFIGS_REGEN=1 "$BUILD_SH" all >/tmp/configs-regen.log 2>&1; then
      echo "[pre-commit] 2_configs/build.sh failed — aborting commit. See /tmp/configs-regen.log" >&2
      tail -20 /tmp/configs-regen.log >&2
      exit 1
    fi
    # Auto-stage regenerated dist files (only if content actually changed)
    if ! git diff --quiet -- 2_configs/dist/; then
      git add 2_configs/dist/
      echo "[pre-commit] 2_configs/dist/ updated + staged."
    fi
  fi
fi
