{
  "name": "MyHealth FeedYourself",
  "framework": "vanilla",
  "port": 8007,
  "src": "src_0",
  "dist": "dist",
  "build": [
    {
      "_doc": "Wrap every *.json in src/data/ as a globalThis.PORTAL_DATA[<key>] companion (data-*.json.js). Engine: front-data-json-js-wrapper.sh.",
      "mod": "data_wrap",
      "dir": "src/data"
    },
    {
      "_doc": "Ship the wrapped data-*.json.js companions to dist/ root, so HTML can load them with <script src=\"data-<KEY>.json.js\"></script> — no fetch, no CORS.",
      "mod": "copy",
      "files": "data-*.json.js",
      "from": "src/data"
    },
    {
      "mod": "sass",
      "input": "src_0/scss/main.scss",
      "output": "style0.css"
    },
    {
      "mod": "esbuild",
      "input": "src_0/typescript/main.ts",
      "output": "script0.js",
      "format": "iife",
      "target": "es2015"
    },
    {
      "mod": "sass",
      "input": "src_2/scss/main.scss",
      "output": "style2.css"
    },
    {
      "mod": "esbuild",
      "input": "src_2/typescript/main.ts",
      "output": "script2.js",
      "format": "iife",
      "target": "es2015"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src_0"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src_1"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src_2"
    },
    {
      "mod": "symlink",
      "files": "public"
    },
    {
      "_doc": "MUST run last — hashes the dist artifacts above to derive BUILD_HASH and inject it into the SW bundle.",
      "mod": "esbuild_sw",
      "input": "src/typescript/script-service-worker.ts",
      "output": "script-service-worker.js",
      "format": "iife",
      "target": "es2020",
      "hash_of": [
        "feed_yourself.html",
        "index.html",
        "script0.js",
        "script2.js",
        "style0.css",
        "style2.css"
      ],
      "precache": [
        "./",
        "./feed_yourself.html",
        "./index.html",
        "./script0.js",
        "./script2.js",
        "./style0.css",
        "./style2.css"
      ]
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "dist"
  },
  "deploy": {}
}
