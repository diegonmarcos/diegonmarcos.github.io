{
  "_doc": "Single source of truth for the generated-file banner injected by all workflow engines. Edit this file to change the stamp shape/wording — every engine that sources inject-header.sh picks up the new template on next build. Placeholders interpolated at build time: {{SOURCE}}, {{ENGINE}}, {{REBUILD_CMD}}.",
  "template": [
    "╔══════════════════════════════════════════════════════════════════╗",
    "║                                                                  ║",
    "║   GENERATED FILE — DO NOT EDIT                                   ║",
    "║                                                                  ║",
    "║   Source : {{SOURCE}}",
    "║   Engine : {{ENGINE}}",
    "║   Rebuild: {{REBUILD_CMD}}",
    "║                                                                  ║",
    "║   Manual edits will be overwritten on next build.                ║",
    "║                                                                  ║",
    "╚══════════════════════════════════════════════════════════════════╝"
  ],
  "rebuild_cmd": "./1_workflows/build.sh",
  "comment_by_ext": {
    "yml":      "#",
    "yaml":     "#",
    "sh":       "#",
    "bash":     "#",
    "zsh":      "#",
    "fish":     "#",
    "nix":      "#",
    "toml":     "#",
    "conf":     "#",
    "cfg":      "#",
    "ini":      "#",
    "py":       "#",
    "rb":       "#",
    "pl":       "#",
    "tf":       "#",
    "tfvars":   "#",
    "hcl":      "#",
    "env":      "#",
    "envrc":    "#",
    "service":  "#",
    "socket":   "#",
    "timer":    "#",
    "mount":    "#",
    "template": "#",
    "tpl":      "#",

    "js":       "//",
    "mjs":      "//",
    "cjs":      "//",
    "ts":       "//",
    "tsx":      "//",
    "jsx":      "//",
    "rs":       "//",
    "go":       "//",
    "c":        "//",
    "h":        "//",
    "cpp":      "//",
    "hpp":      "//",
    "cc":       "//",
    "hh":       "//",
    "java":     "//",
    "kt":       "//",
    "swift":    "//",
    "scss":     "//",
    "sass":     "//",
    "css":      "//",
    "less":     "//",

    "sql":      "--",
    "lua":      "--",
    "hs":       "--"
  },
  "comment_by_basename": {
    "pre-commit":    "#",
    "post-checkout": "#",
    "post-merge":    "#",
    "pre-push":      "#",
    "gitignore":     "#",
    "gitmodules":    "#",
    "gitconfig":     "#",
    ".gitignore":    "#",
    ".gitmodules":   "#",
    "Dockerfile":    "#",
    "Dockerfile.native": "#",
    "Dockerfile.configs": "#",
    "Makefile":      "#",
    "Justfile":      "#",
    ".env":          "#",
    ".envrc":        "#",
    ".dockerignore": "#"
  },
  "special": {
    "json":  { "mode": "meta_key",     "key": "_generated" },
    "json5": { "mode": "line_comment", "prefix": "//" },
    "jsonc": { "mode": "line_comment", "prefix": "//" }
  },
  "shebang_aware": true,
  "skip_extensions": ["png", "jpg", "jpeg", "gif", "webp", "ico", "pdf", "tar", "gz", "zip", "nar", "min.js"],
  "skip_basenames": [
    ".terraform.lock.hcl",
    "terraform.tfstate",
    "terraform.tfstate.backup",
    "terraform.tfvars",
    "flake.lock",
    "package-lock.json",
    "yarn.lock",
    "Cargo.lock",
    "go.sum"
  ],
  "marker": "GENERATED FILE — DO NOT EDIT"
}
