{
  "name": "Cloud",
  "framework": "vanilla",
  "port": 8006,
  "src": "src",
  "dist": "dist",
  "build": [
    {
      "_doc": "Wrap every *.json in src/data/ as a globalThis.PORTAL_DATA[<key>] companion (data-*.json.js). Engine: front-data-json-js-wrapper.sh.",
      "mod": "data_wrap",
      "dir": "src/data"
    },
    {
      "_doc": "Ship the wrapped data-*.json.js companions to dist/ root, so HTML can load them with <script src=\"data-<KEY>.json.js\"></script> — no fetch, no CORS.",
      "mod": "copy",
      "files": "data-*.json.js",
      "from": "src/data"
    },
    {
      "mod": "sass",
      "input": "src/scss/main.scss",
      "output": "styles.css"
    },
    {
      "mod": "esbuild",
      "input": "src/typescript/main.ts",
      "output": "script.js",
      "format": "iife",
      "target": "es2015"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src"
    },
    {
      "mod": "copy",
      "files": "*.js",
      "from": "src",
      "exclude": "script.js"
    },
    {
      "mod": "symlink",
      "files": "public"
    },
    {
      "_doc": "Inject navigator.serviceWorker.register(...) before </head>. MUST run BEFORE esbuild_sw so the modified HTML feeds into BUILD_HASH.",
      "mod": "sw_register",
      "files": "architecture.html, cloud_control.html, error.html, feed_docs.html, index.html, oauth-callback.html, products.html"
    },
    {
      "_doc": "MUST run last — hashes the dist artifacts above to derive BUILD_HASH and inject it into the SW bundle.",
      "mod": "esbuild_sw",
      "input": "src/typescript/script-service-worker.ts",
      "output": "script-service-worker.js",
      "format": "iife",
      "target": "es2020",
      "hash_of": [
        "architecture.html",
        "availability.js",
        "cloud_control.html",
        "costs.js",
        "docker.js",
        "error.html",
        "feed_docs.html",
        "index.html",
        "monitor.js",
        "oauth-callback.html",
        "performance.js",
        "products.html",
        "script.js",
        "security.js",
        "styles.css",
        "web.js"
      ],
      "precache": [
        "./",
        "./architecture.html",
        "./availability.js",
        "./cloud_control.html",
        "./costs.js",
        "./docker.js",
        "./error.html",
        "./feed_docs.html",
        "./index.html",
        "./monitor.js",
        "./oauth-callback.html",
        "./performance.js",
        "./products.html",
        "./script.js",
        "./security.js",
        "./styles.css",
        "./web.js"
      ]
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "src",
    "watch": [
      {
        "mod": "sass",
        "input": "scss/main.scss",
        "output": "styles.css"
      },
      {
        "mod": "esbuild",
        "input": "typescript/main.ts",
        "output": "script.js",
        "format": "iife",
        "target": "es2015"
      }
    ]
  },
  "deploy": {}
}
