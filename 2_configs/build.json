{
  "_doc": "front/2_configs — unified-manifest consolidator + per-project deriver. Mirrors cloud/2_configs pattern. Single SoT pipeline: src/* (symlinks to raw inputs) → consolidator → dist/_front-data-consolidated.json → derivers → dist/{front-data-*.json, build-<cat>__<proj>.json}.",
  "name": "2_configs",
  "framework": "vanilla",
  "src": "src",
  "dist": "dist",
  "build": {
    "type": "script-only",
    "entry": "build.sh"
  },
  "inputs": {
    "_doc": "Symlinks populated by build.sh populate-src.",
    "builds":         { "from_glob": "**/build.json",                    "into": "src/builds/<cat>__<proj>.build.json" },
    "data_links":     { "from": "a-Portals/linktree/src/data/*.json",     "into": "src/data-links/<file>" },
    "ship_yml":       { "from": "1_workflows/src/cicd/ship.yml",          "into": "src/inputs/ship.yml" },
    "root_config":    { "from": "config.json",                            "into": "src/inputs/config.json" },
    "package_jsons":  { "from_glob": "**/package.json",                   "into": "src/inputs/package-jsons/<cat>__<proj>.json" },
    "manifests":      { "from_glob": "**/manifest.webmanifest",           "into": "src/inputs/manifests/<cat>__<proj>.webmanifest" }
  },
  "outputs": {
    "_doc": "Generated by build.sh build → consolidate → derive.",
    "consolidated": "dist/_front-data-consolidated.json",
    "per_concern": [
      "dist/front-data-builds.json",
      "dist/front-data-projects.json",
      "dist/front-data-links.json",
      "dist/front-data-deploys.json",
      "dist/front-data-deps.json",
      "dist/front-data-categories.json",
      "dist/front-data-analytics.json",
      "dist/front-data-pwa.json"
    ],
    "per_project_glob": "dist/build-<cat>__<proj>.json",
    "manifest": "dist/manifest.json"
  },
  "validators": [
    "validate-link-targets",
    "validate-deploy-coverage"
  ],
  "deploy": {}
}
