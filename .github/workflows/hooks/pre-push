#!/usr/bin/env bash

# ╔══════════════════════════════════════════════════════════════════╗
# ║                                                                  ║
# ║   GENERATED FILE — DO NOT EDIT                                   ║
# ║                                                                  ║
# ║   Source : 1_workflows/src/hooks/pre-push
# ║   Engine : 1_workflows/src/scripts/front-ship-repo-workflow-engine.sh
# ║   Rebuild: ./1_workflows/build.sh
# ║                                                                  ║
# ║   Manual edits will be overwritten on next build.                ║
# ║                                                                  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ╔══════════════════════════════════════════════════════════════════╗
# ║ pre-push — rebase submodules onto their upstream HEAD            ║
# ║                                                                  ║
# ║ Source: cloud/1_workflows/src/hooks/pre-push                     ║
# ║ Active via [core] hooksPath = 1_workflows/dist/hooks             ║
# ║                                                                  ║
# ║ Before every push, sync each submodule worktree to its remote    ║
# ║ HEAD (rebased). Pointer bumps in the parent repo are NOT         ║
# ║ auto-staged — that remains the responsibility of the GHA         ║
# ║ sync-submodules workflow on main. This hook only ensures the     ║
# ║ local worktree reflects upstream before the push goes out.       ║
# ╚══════════════════════════════════════════════════════════════════╝
set -uo pipefail

# ── Safer-alternative reminder ──────────────────────────────────────
if [ -t 2 ]; then
  printf '\033[33m\n┌─ git push ─ tip ──────────────────────────────────────────────┐\n' >&2
  printf   '│ Prefer `git sync` — safer: auto-stash + rebase + submodules.  │\n' >&2
  printf   '│   git sync remote   (origin wins on conflict, default)        │\n' >&2
  printf   '│   git sync local    (local commits win on conflict)           │\n' >&2
  printf   '│   script: 1_workflows/dist/scripts/cloud-git-sync.sh          │\n' >&2
  printf   '└───────────────────────────────────────────────────────────────┘\033[0m\n' >&2
fi

# Skip during interactive rebase / merge / bisect — don't compound state.
if [ -d "$(git rev-parse --git-path rebase-merge 2>/dev/null)" ] \
   || [ -d "$(git rev-parse --git-path rebase-apply 2>/dev/null)" ] \
   || [ -f "$(git rev-parse --git-path MERGE_HEAD   2>/dev/null)" ] \
   || [ -f "$(git rev-parse --git-path BISECT_LOG   2>/dev/null)" ]; then
  exit 0
fi

# Skip if no submodules declared
[ -f .gitmodules ] || exit 0

echo "[pre-push] rebasing submodules onto upstream HEAD..."
if ! git submodule update --init --recursive --remote --rebase; then
  echo "[pre-push] submodule rebase reported errors — continuing (non-blocking)." >&2
fi
exit 0
