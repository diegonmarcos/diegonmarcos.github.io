{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src/typescript",
    "declaration": false,
    "noEmit": true
  },
  "include": ["src/typescript/**/*"],
  "exclude": ["node_modules", "dist"]
}
