{
  "name": "MyHealth FeedYourself",
  "framework": "vanilla",
  "port": 8007,
  "src": "src/src-index",
  "dist": "dist",
  "build": [
    {
      "_doc": "Merge USDA SR Legacy + GI overlay + food-table-inputs.json -> src/data/food-library.json. Must run BEFORE data_wrap.",
      "mod": "npm",
      "script": "build:data"
    },
    {
      "_doc": "Wrap every *.json in src/data/ as a globalThis.PORTAL_DATA[<key>] companion (data-*.json.js). Engine: front-data-json-js-wrapper.sh.",
      "mod": "data_wrap",
      "dir": "src/data"
    },
    {
      "_doc": "Ship the wrapped data-*.json.js companions to dist/ root, so HTML can load them with <script src=\"data-<KEY>.json.js\"></script> — no fetch, no CORS.",
      "mod": "copy",
      "files": "data-*.json.js",
      "from": "src/data"
    },
    {
      "mod": "sass",
      "input": "src/src-index/scss/main.scss",
      "output": "style-index.css"
    },
    {
      "mod": "esbuild",
      "input": "src/src-index/typescript/main.ts",
      "output": "script-index.js",
      "format": "iife",
      "target": "es2015"
    },
    {
      "mod": "sass",
      "input": "src/src-recipes/scss/main.scss",
      "output": "style-recipes.css"
    },
    {
      "mod": "esbuild",
      "input": "src/src-recipes/typescript/main.ts",
      "output": "script-recipes.js",
      "format": "iife",
      "target": "es2015"
    },
    {
      "mod": "sass",
      "input": "src/src-food-tables/scss/main.scss",
      "output": "style-food-tables.css"
    },
    {
      "mod": "esbuild",
      "input": "src/src-food-tables/typescript/main.ts",
      "output": "script-food-tables.js",
      "format": "iife",
      "target": "es2015"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src/src-index"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src/src-meal-designer"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src/src-recipes"
    },
    {
      "mod": "copy",
      "files": "*.html",
      "from": "src/src-food-tables"
    },
    {
      "mod": "symlink",
      "files": "public"
    },
    {
      "_doc": "Inject navigator.serviceWorker.register(...) before </head>. MUST run BEFORE esbuild_sw so the modified HTML feeds into BUILD_HASH.",
      "mod": "sw_register",
      "files": "index.html, meal_designer.html, recipes.html, food_tables.html"
    },
    {
      "_doc": "Inject single-namespace observability SDK (Sentry/OpenObserve-style). Mirrors console.* + errors + SW lifecycle to OPFS console.log. window.consoleLogs.{captureException, captureMessage, addBreadcrumb, read, readJSON, tail, clear, download}.",
      "mod": "console_log",
      "files": "index.html, meal_designer.html, recipes.html, food_tables.html"
    },
    {
      "_doc": "MUST run last — hashes the dist artifacts above to derive BUILD_HASH and inject it into the SW bundle.",
      "mod": "esbuild_sw",
      "input": "src/typescript/script-service-worker.ts",
      "output": "script-service-worker.js",
      "format": "iife",
      "target": "es2020",
      "hash_of": [
        "index.html",
        "meal_designer.html",
        "recipes.html",
        "food_tables.html",
        "script-index.js",
        "script-recipes.js",
        "script-food-tables.js",
        "style-index.css",
        "style-recipes.css",
        "style-food-tables.css",
        "data-food-library.json.js"
      ],
      "precache": [
        "./",
        "./index.html",
        "./meal_designer.html",
        "./recipes.html",
        "./food_tables.html",
        "./script-index.js",
        "./script-recipes.js",
        "./script-food-tables.js",
        "./style-index.css",
        "./style-recipes.css",
        "./style-food-tables.css",
        "./data-food-library.json.js"
      ]
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "dist"
  },
  "deploy": {},
  "_resolved": {
    "path": "c-Suite/myhealth-feedyourself",
    "category": "c-Suite",
    "project": "myhealth-feedyourself",
    "key": "c-Suite__myhealth-feedyourself",
    "port": 8007,
    "framework": "vanilla",
    "src": "src/src-index",
    "dist": "dist",
    "analytics": {
      "matomo": {
        "container_id": "container_odwLIyPV",
        "url": "https://analytics.diegonmarcos.com/js/container_odwLIyPV.js"
      },
      "umami": {
        "site_id": "937cbde7-5ec2-450c-9d6a-8117423ac12f",
        "url": "https://analytics.diegonmarcos.com/umami/script.js"
      }
    },
    "deploy": {
      "deployed": true,
      "deploy_name": "myhealth-feedyourself",
      "url": "https://diegonmarcos.github.io/myhealth-feedyourself"
    },
    "consumers": [
      "FeedYourself"
    ],
    "has_package_json": true,
    "has_manifest": false
  }
}
