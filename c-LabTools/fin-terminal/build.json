{
  "name": "FinTerminal",
  "framework": "vanilla",
  "port": 8024,
  "src": "src",
  "dist": "dist",
  "api": {
    "base": "https://api.diegonmarcos.com/fin-api",
    "ws": "wss://api.diegonmarcos.com/fin-api/api/v1/ws"
  },
  "apps": {
    "valuation": {
      "url": "/valuation/",
      "_note": "Valuation Modelling section. Set to empty string to show placeholder until the valuation app is wired."
    }
  },
  "build": [
    {
      "_doc": "Wrap every *.json in src/data/ as a globalThis.PORTAL_DATA[<key>] companion (data-*.json.js). Engine: front-data-json-js-wrapper.sh.",
      "mod": "data_wrap",
      "dir": "src/data"
    },
    {
      "_doc": "Ship the wrapped data-*.json.js companions to dist/ root, so HTML can load them with <script src=\"data-<KEY>.json.js\"></script> — no fetch, no CORS.",
      "mod": "copy",
      "files": "data-*.json.js",
      "from": "src/data"
    },
    {
      "mod": "sass",
      "input": "src/scss/main.scss",
      "output": "style.css"
    },
    {
      "mod": "esbuild",
      "input": "src/typescript/main.ts",
      "output": "script.js",
      "format": "iife",
      "target": "es2020"
    },
    {
      "mod": "copy",
      "files": "index.html",
      "from": "src"
    },
    {
      "mod": "symlink",
      "files": "public"
    },
    {
      "_doc": "MUST run last — hashes the dist artifacts above to derive BUILD_HASH and inject it into the SW bundle.",
      "mod": "esbuild_sw",
      "input": "src/typescript/script-service-worker.ts",
      "output": "script-service-worker.js",
      "format": "iife",
      "target": "es2020",
      "hash_of": [
        "index.html",
        "script.js",
        "style.css"
      ],
      "precache": [
        "./",
        "./index.html",
        "./script.js",
        "./style.css"
      ]
    }
  ],
  "serve": {
    "mode": "auto",
    "dir": "src",
    "watch": [
      {
        "mod": "sass",
        "input": "scss/main.scss",
        "output": "style.css"
      },
      {
        "mod": "esbuild",
        "input": "typescript/main.ts",
        "output": "script.js",
        "format": "iife",
        "target": "es2020"
      }
    ]
  },
  "deploy": {}
}
